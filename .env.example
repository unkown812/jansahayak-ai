# JanSahayak AI Environment Configuration

# 1. Google Gemini API Key (Required for live AI transcribing and directive generation)
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# 2. Google Maps JavaScript API Key (Required for live Google Maps rendering and coordinates plotting)
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# 3. Supabase Credentials (Required for real Google login auth provider)
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here